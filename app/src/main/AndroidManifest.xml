<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Required to run EngineService as a foreground service (API 28+) and to declare its
         special-use category (API 34+); see services/EngineService.kt for why "specialUse"
         is the right foreground service type when no other category fits. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <!-- Required on API 33+ for the foreground service notification to actually be visible;
         requesting this at runtime is deferred to a future phase (Settings/permissions UI). -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".BehaviorEngineApp"
        android:allowBackup="true"
        android:icon="@drawable/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@drawable/ic_launcher"
        android:supportsRtl="true"
        android:theme="@style/Theme.BehaviorEngine">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.BehaviorEngine">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name=".services.EngineService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="behavior_engine_runtime" />
        </service>
    </application>

</manifest>
